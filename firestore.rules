rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper: check if current user is an admin
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email == 'vjysupermacy@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.token.email))
      );
    }

    // Helper: user is signed in
    function isSignedIn() {
      return request.auth != null;
    }

    // Podcasts: anyone can read, only admins can write
    match /podcasts/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Webinars: anyone can read, only admins can write
    match /webinars/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Glimpses: anyone can read, only admins can write
    match /glimpses/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Programs (Our Programs page): public read, admin write
    match /programs/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Site copy (About page: paragraphs + SCORE bullets): public read, admin write
    match /siteContent/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Admins: only super admin (vjysupermacy@gmail.com) can manage
    match /admins/{email} {
      allow read: if isAdmin();
      allow create, update, delete: if request.auth != null && 
        request.auth.token.email == 'vjysupermacy@gmail.com';
    }
  }
}
